RAILS_ENV=development
# Канонический URL сайта (RSS, Disqus, абсолютные ссылки). Без завершающего /
APP_URL=http://localhost:3000

# Логи в консоль Docker (`docker compose logs -f app`); без этого — только log/development.log
RAILS_LOG_TO_STDOUT=true
# Подробность: debug | info | warn | error | fatal
LOG_LEVEL=debug

DB_HOST=db
# Только для локального dev; в общих сетях задайте уникальные пароли
DB_USERNAME=root
DB_PASSWORD=root
DB_NAME=zxevo_development
DB_TEST_NAME=zxevo_test

SECRET_KEY_BASE=dev_secret_key_base_for_docker

# Должен совпадать с тем, что ожидает образ MySQL для root (только для dev)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=zxevo_development
