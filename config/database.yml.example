default: &default
  adapter: mysql2
  encoding: utf8mb4
  collation: utf8mb4_unicode_ci
  pool: <%= ENV.fetch('RAILS_MAX_THREADS', 5) %>
  username: <%= ENV.fetch('DB_USERNAME', 'root') %>
  password: <%= ENV.fetch('DB_PASSWORD', '') %>
  host: <%= ENV.fetch('DB_HOST', '127.0.0.1') %>
  port: <%= ENV.fetch('DB_PORT', 3306) %>

development:
  <<: *default
  database: <%= ENV.fetch('DB_NAME', 'zxevo_development') %>

test:
  <<: *default
  database: <%= ENV.fetch('DB_TEST_NAME', 'zxevo_test') %>

production:
  <<: *default
  database: <%= ENV.fetch('DB_NAME', 'zxevo_production') %>
