# Скопируйте в .env.production и подставьте секреты (файл не коммитить).
# Использование: docker compose -f docker-compose.production.yml --env-file .env.production up -d --build

RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true
LOG_LEVEL=info

# Публичный URL сайта (https://…), без завершающего /
APP_URL=https://example.com

# Обязательно сгенерировать: openssl rand -hex 64
SECRET_KEY_BASE=

# Пользователь приложения и пароль (должны совпадать с MYSQL_USER / MYSQL_PASSWORD ниже)
DB_USERNAME=zxevo
DB_PASSWORD=
DB_NAME=zxevo_production
DB_PORT=3306

# Root MySQL в контейнере `db`
MYSQL_ROOT_PASSWORD=

# Порт на хосте (слева в mapping host:container)
APP_PUBLISH_PORT=3000

# Puma: один процесс (WEB_CONCURRENCY=0), один поток — минимум RAM/CPU на слабом сервере
WEB_CONCURRENCY=0
RAILS_MAX_THREADS=1

# Миграции при старте контейнера app (true | false)
RUN_DB_MIGRATE_ON_START=true
